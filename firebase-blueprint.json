{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and settings",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" }
      },
      "required": ["email"]
    },
    "Movie": {
      "title": "Movie",
      "description": "A movie or TV show in the database",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "type": { "type": "string", "enum": ["movie", "tv", "anime"] },
        "posterUrl": { "type": "string" },
        "backdropUrl": { "type": "string" },
        "score": { "type": "number" },
        "year": { "type": "number" },
        "genres": { "type": "array", "items": { "type": "string" } },
        "tags": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["title", "type"]
    },
    "WatchlistItem": {
      "title": "Watchlist Item",
      "description": "An item saved to a user's watchlist",
      "type": "object",
      "properties": {
        "contentId": { "type": "string" },
        "addedAt": { "type": "number" }
      },
      "required": ["contentId", "addedAt"]
    },
    "ProgressItem": {
      "title": "Progress Item",
      "description": "Tracking user's watch progress",
      "type": "object",
      "properties": {
        "contentId": { "type": "string" },
        "progress": { "type": "number" },
        "duration": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["contentId", "progress", "updatedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User definitions and global settings"
    },
    "/users/{userId}/watchlist/{itemId}": {
      "schema": { "$ref": "#/entities/WatchlistItem" },
      "description": "User's watchlist"
    },
    "/users/{userId}/progress/{progressId}": {
      "schema": { "$ref": "#/entities/ProgressItem" },
      "description": "User's watch progress"
    },
    "/content/{contentId}": {
      "schema": { "$ref": "#/entities/Movie" },
      "description": "Global catalog of movies and TV shows"
    }
  }
}
