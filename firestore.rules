rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }

    function isValidUser(data) {
      return data.keys().hasAny(['email']) 
        && data.email is string && data.email.size() <= 200;
    }

    function isValidWatchlistItem(data) {
      return data.keys().hasAll(['contentId', 'addedAt'])
        && data.keys().size() <= 3
        && data.contentId is string && data.contentId.size() <= 128
        && data.addedAt is number;
    }

    function isValidProgressItem(data) {
      return data.keys().hasAll(['contentId', 'progress', 'updatedAt'])
        && data.keys().size() <= 5
        && data.contentId is string && data.contentId.size() <= 128
        && data.progress is number
        && data.updatedAt is number;
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming());

      match /watchlist/{itemId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(itemId) && isValidWatchlistItem(incoming());
        allow delete: if isOwner(userId) && isValidId(itemId);
      }

      match /progress/{progressId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(progressId) && isValidProgressItem(incoming());
        allow update: if isOwner(userId) && isValidId(progressId) && isValidProgressItem(incoming());
        allow delete: if isOwner(userId) && isValidId(progressId);
      }
    }

    match /content/{contentId} {
      // Content is globally readable by anyone
      allow read: if true;
      // For now, no client-side writes to content. All updates via Firebase console or Admin SDK.
      allow write: if false; 
    }
  }
}
